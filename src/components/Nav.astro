---
const links = [
	{ href: "/", label: "Home" },
	{ href: "/about/", label: "About" },
	{ href: "/projects/", label: "Projects" },
];
---

<nav>
	{links.map(({ href, label }) => <a href={href}>{label}</a>)}
</nav>

<style>
	nav {
		display: flex;
		gap: 1rem;
		padding: 1rem;
		border-bottom: 1px solid #eee;
	}
	a {
		text-decoration: none;
		color: inherit;
	}
	a:hover {
		text-decoration: underline;
	}
</style>
